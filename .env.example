API_PORT=8787
FRONTEND_ORIGIN=http://localhost:5173
# 여러 배포 도메인을 허용해야 하면 콤마로 구분
# FRONTEND_ORIGIN=https://truve.pages.dev,https://www.truve.example

# 프론트엔드에서 API 호출 시 사용할 base URL
# 로컬: 비워두면 Vite proxy(/api)가 자동 처리
# Cloudflare 배포 시: Railway 서비스 URL (예: https://truve-api.up.railway.app)
# Vite 값은 빌드 시점에 번들에 박히므로 wrangler deploy 전에 반드시 설정
VITE_API_BASE_URL=

# Xaman Platform API credentials (xApp)
XAMAN_API_KEY=
XAMAN_API_SECRET=

# Anthropic Claude API (절세 시뮬레이터)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# XRPL Testnet settings
XRPL_NETWORK=testnet
XRPL_TESTNET_WS=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_WSS=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_DONATION_DESTINATION=ragkA1Swi7Y6mJHXf97QUqKXBm99uGkcVX
XRPL_TESTNET_GOVERNANCE_DESTINATION=ragkA1Swi7Y6mJHXf97QUqKXBm99uGkcVX
XRPL_TESTNET_RLUSD_CURRENCY=RLUSD
XRPL_TESTNET_RLUSD_ISSUER=
XRPL_TESTNET_RLUSD_ISSUER_ADDRESS=
XRPL_TESTNET_RLUSD_ISSUER_SEED=
XRPL_TESTNET_USDC_CURRENCY=USDC
XRPL_TESTNET_USDC_ISSUER=
XRPL_TESTNET_USDC_ISSUER_ADDRESS=
XRPL_TESTNET_USDC_ISSUER_SEED=
ADMIN_FAUCET_ENABLED=true
ADMIN_SECRET=

# Database (Railway PostgreSQL)
# Local: Public URL / Railway 서버: Internal URL
DATABASE_URL=postgresql://postgres:password@host:port/railway
