API_PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# 프론트엔드에서 API 호출 시 사용할 base URL
# 로컬: 비워두면 Vite proxy(/api)가 자동 처리
# Cloudflare 배포 시: Railway 서비스 URL (예: https://truve-api.up.railway.app)
VITE_API_BASE_URL=

# Xaman Platform API credentials (xApp)
XAMAN_API_KEY=
XAMAN_API_SECRET=

# XRPL Testnet settings
XRPL_TESTNET_WS=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_DONATION_DESTINATION=ragkA1Swi7Y6mJHXf97QUqKXBm99uGkcVX
XRPL_TESTNET_GOVERNANCE_DESTINATION=ragkA1Swi7Y6mJHXf97QUqKXBm99uGkcVX

# Database (Railway PostgreSQL)
# Local: Public URL / Railway 서버: Internal URL
DATABASE_URL=postgresql://postgres:password@host:port/railway
